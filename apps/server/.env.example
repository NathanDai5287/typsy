# apps/server/.env — copy to apps/server/.env and fill in real values.
# Loaded at server startup by `import 'dotenv/config'` in src/index.ts.
# DO NOT COMMIT a populated .env. The .gitignore covers .env files.

# ─── Firebase Admin (REQUIRED unless BYPASS_AUTH=1) ──────────────────────
# Either provide GOOGLE_APPLICATION_CREDENTIALS (canonical) ...
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
#
# ...or paste the three fields from the downloaded service-account JSON
# directly. The private key has its newlines escaped as \n; do not unescape
# them here — auth.ts handles that.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Owner UID — the Firebase UID of the Google account that should be linked
# to user_id=1 (the row that holds your existing pre-auth practice data).
# Find it in Firebase Console → Authentication → Users after your first
# sign-in. Leave blank to disable the auto-link (everyone, including you,
# gets a fresh user row).
TYPSY_OWNER_FIREBASE_UID=

# ─── Server config ────────────────────────────────────────────────────────
# Port the Express process listens on. Cloudflare tunnel maps typsy.cal.taxi
# to this port, so changing it requires updating /etc/cloudflared/config.yml.
PORT=3001

# Comma-separated list of extra origins allowed to call /api/*. Localhost dev
# (5173) is always allowed. Add a Vercel/Netlify URL here when split-deploying.
# Example: ALLOWED_ORIGIN=https://typsy.vercel.app,https://staging.typsy.app
ALLOWED_ORIGIN=

# ─── Dev escape hatch ────────────────────────────────────────────────────
# Skip Firebase token verification entirely. The server reads the user_id
# from the legacy real/synthetic switcher (TYPSY_DATA_MODE). Use this for
# local development when you don't want to set up Firebase. NEVER set this
# on the production server.
# BYPASS_AUTH=1

# Real (1) vs synthetic (2) user, only consulted when BYPASS_AUTH=1. Leave
# unset for the real user, set to `synthetic` for the seeded demo data.
# TYPSY_DATA_MODE=
