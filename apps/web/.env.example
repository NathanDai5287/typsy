# apps/web/.env — copy to apps/web/.env.local and fill in real values.
# Vite reads .env.local automatically. DO NOT COMMIT a populated file.
#
# These values are publicly embedded in the client bundle at build time.
# They are NOT secrets — they identify which Firebase project the SPA
# should talk to. Security is enforced server-side by token verification.
# (Treat the service-account JSON on the server as the actual secret.)
#
# Get these from Firebase Console → Project Settings → General →
# "Your apps" → Web app → SDK setup and configuration.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Optional. Default: '/api' (same-origin — works when Express serves the
# SPA). Set to the full backend origin when split-deploying frontend to
# Vercel / Cloudflare Pages and backend on typsy.cal.taxi.
# Example: VITE_API_BASE_URL=https://typsy.cal.taxi/api
VITE_API_BASE_URL=

# Optional dev escape hatch. Mirror of the server's BYPASS_AUTH=1: skip
# Firebase entirely on the frontend (no popup, no token). The server must
# also have BYPASS_AUTH=1 set or every request will 401.
# VITE_BYPASS_AUTH=1
